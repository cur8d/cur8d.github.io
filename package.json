    "@vitest/coverage-v8": "4.1.6",
    "eslint": "9.19.0",
    "eslint-config-next": "16.2.6",
    "firebase-tools": "^13.31.1",
    "globals": "^17.6.0",
    "jsdom": "26.0.0",
    "playwright": "1.59.1",
    "prettier": "3.4.2",
