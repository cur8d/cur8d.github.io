    "cmdk": "1.0.0",
    "framer-motion": "12.0.0",
    "lucide-react": "0.474.0",
    "next": "16.2.6",
    "next-themes": "0.4.4",
    "postcss": "^8.5.15",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "9.19.0",
    "@next/bundle-analyzer": "16.2.6",
    "@next/eslint-plugin-next": "^16.2.6",
